# Google Places API Configuration
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Make sure to enable the Places API (New) and Geocoding API
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Note: The gym finder will work with mock data if this API key is not provided
# For production use, you should implement a backend proxy to avoid exposing your API key